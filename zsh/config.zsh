# Zsh options not covered by Prezto modules

setopt NO_LIST_BEEP     # don't beep on ambiguous completion
setopt LOCAL_OPTIONS    # allow functions to have local options
setopt LOCAL_TRAPS      # allow functions to have local traps
setopt IGNORE_EOF       # don't exit on Ctrl-D
setopt HIST_REDUCE_BLANKS  # remove superfluous blanks from history entries
