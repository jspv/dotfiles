# Usage: search-shellfunctions <search1> [search2] ...
# Searches shellfunctions for each of the terms provided
function search-shellfunctions() {
  typeset -A grepaliases
  typeset -A newaliases
  grepaliases=( "${(@kv)functions}" )
  # loop through each of the arguments and keep the functions that match
  for arg in $@; do
    for key value in ${(kv)grepaliases}; do
      # :u markes them as uppercase to do insenstive matching
      if [[ ${key:u} = *${arg:u}* ]] || [[ ${value:u} = *${arg:u}* ]]; then
        newaliases+=("$key" "$value")
      fi
    done
    grepaliases=( "${(@kv)newaliases}" )
    newaliases=()
  done

  # output similar to a alias | grep -i
  for key in ${(ki)grepaliases}; do
    print "$key"
    # the following prints the function which can get messy
    # print "$key='${grepaliases[$key]}'"
  done
}
